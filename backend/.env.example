PORT=3000
FRONTEND_PUBLIC_URL="http://localhost:8080"

# Use esta URL se preferir manter a configuracao do banco dentro do backend.
# Ela sobrescreve a DATABASE_URL da raiz quando backend/.env existir.
DATABASE_URL="postgresql://coepay_user:coepay_dev@localhost:5432/coepay"
DATABASE_SSL=false
SETTINGS_ENCRYPTION_KEY="troque-por-uma-chave-longa-e-secreta"

GOOGLE_CLIENT_ID="seu-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="sua-chave-secreta"
GOOGLE_CALLBACK_URL="http://localhost:3000/auth/google/callback"

# SMTP central do sistema. O usuario final nao ve nem altera estes dados.
# O e-mail da empresa salvo em Comunicacoes entra apenas como replyTo/contato.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="naorespondacoepay@gmail.com"
SMTP_PASS="senha-de-app-do-gmail"
SMTP_FROM="CoéPay <naorespondacoepay@gmail.com>"

EMAIL_REMINDERS_ENABLED=false
EMAIL_REMINDER_CRON="0 9 * * *"
EMAIL_REMINDER_TIMEZONE="America/Sao_Paulo"
EMAIL_REMINDERS_RUN_ON_START=false
