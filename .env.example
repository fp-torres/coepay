# Frontend
VITE_API_URL="http://localhost:3000"

# Supabase e Stripe sao opcionais neste projeto local.
# Deixe vazio enquanto estiver rodando somente com PostgreSQL local.
VITE_SUPABASE_URL=""
VITE_SUPABASE_PUBLISHABLE_KEY=""

# Backend / PostgreSQL local
DATABASE_URL="postgresql://coepay_user:coepay_dev@localhost:5432/coepay"
DATABASE_SSL=false
SETTINGS_ENCRYPTION_KEY="troque-por-uma-chave-longa-e-secreta"

# Backend / SMTP central
# Nao use VITE_ para segredos. Em producao, prefira configurar isto no servidor.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="naorespondacoepay@gmail.com"
SMTP_PASS="senha-de-app-do-gmail"
SMTP_FROM="CoéPay <naorespondacoepay@gmail.com>"
